{
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "outputStyle": "Explanatory",
  "permissions": {
    "allow": [
      "Bash(find:*)",
      "Bash(grep:*)",
      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:gist.github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Bash(git log:*)"
    ]
  },
  "model": "opus[1m]",
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/claude-notify.sh 'I have finished the current task'"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/claude-notify.sh 'Permission request'"
          }
        ]
      }
    ]
  },
  "alwaysThinkingEnabled": true,
  "showThinkingSummaries": true,
  "feedbackSurveyRate": 0,
  "effortLevel": "85"
}
